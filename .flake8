[flake8]
max-line-length = 88
extend-ignore = E203, E501, W503
exclude =
    .git,
    __pycache__,
    _isaac_sim,
    build,
    dist,
    *.egg-info,
    .venv,
    venv,
    .tox,
    .pytest_cache,
    .mypy_cache,
    .coverage,
    htmlcov,
    .DS_Store,
    .vscode,
    .idea
per-file-ignores =
    __init__.py:F401
    tests/*:S101
    scripts/*:S101
    tools/*:S101